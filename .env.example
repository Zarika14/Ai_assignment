# ==============================================================================
# AI Engineer Assignment — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore and will NOT be committed to git.
# .env.example IS committed — it serves as documentation for all settings.
# ==============================================================================


# ------------------------------------------------------------------------------
# PART 1 — Model Server (model_server/main.py)
# ------------------------------------------------------------------------------

# Ollama base URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use via Ollama (must be pulled first: ollama pull mistral:latest)
MODEL_NAME=mistral:latest

# Port the model server runs on
MODEL_SERVER_PORT=8000


# ------------------------------------------------------------------------------
# PART 3 — Agent (agent/agent.py + agent/server.py)
# ------------------------------------------------------------------------------

# Port the agent server runs on
AGENT_SERVER_PORT=8001

# URL of the model server that the agent calls
MODEL_SERVER_URL=http://localhost:8000

# --- BONUS: PostgreSQL Session Persistence ---
# If set, agent sessions are persisted to PostgreSQL instead of in-memory.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Leave blank to use in-memory sessions (default).
# Example (local Docker Postgres):
#   docker run -d --name pg -e POSTGRES_PASSWORD=secret \
#              -e POSTGRES_DB=agentdb -p 5432:5432 postgres:14
DATABASE_URL= "postgresql://postgres:pass@localhost:5432/agentdb"

# --- BONUS: Fine-Tuned TinyLlama Backbone ---
# Set to "true" to use the locally fine-tuned TinyLlama-1.1B + LoRA adapter
# as the agent's LLM instead of calling Ollama.
# Requires: finetune/tinyllama_lora_adapter/ to exist (run finetune/train_tiny.py first)
# Default: false (uses Ollama/Mistral-7B for better tool-calling reliability)
USE_FINETUNED_BACKBONE=false


# ------------------------------------------------------------------------------
# PART 5 — Evaluation (eval/run_evals.py)
# ------------------------------------------------------------------------------

# URL of the model server used by the LLM-as-judge in evaluations
EVAL_MODEL_SERVER_URL=http://localhost:8000
